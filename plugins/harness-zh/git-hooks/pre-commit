#!/bin/bash
# Harness pre-commit hook
#
# 单 gate：retro action items checker — staged diff 含 [4-6]-*.md 新建时触发
#
# 其它 commit 一概放行（包括 C2-C9 自身、Epic 1-3 改动、文档、tests、删除
# 老 4-x-*.md 等清理操作）。
#
# `git commit --no-verify` 显式保留；solo-dev 必要时绕过——但应**在被绕过的
# retro action item 自身的 sprint-status.yaml 行注释里**加备注，让未来 retro
# 审计能看到跳过痕迹（commit message 是 ephemeral 的；yaml 注释持久）。
#
# 仓库源：.claude/harness/git-hooks/pre-commit  → 由 .claude/harness/scripts/install_git_hooks.sh
# 安装到 .git/hooks/pre-commit（git 不追踪 .git/hooks/ 内文件）。
#
# v1 → v1.1 (review patches 2026-05-03)：E10 checker 缺失 distinct error、
# E11 `--diff-filter=A` 排除 rename / delete、A8 bypass 文字对齐 spec frozen。
# v1.2 → v1.3 (2026-05-05)：删除 D5 引入的 gate ② 继承段约束（零实战 +
# false positive 阻塞 epic-5 stage ③ codex-review.md）；继承段质量回归
# spec 作者人肉守门 + retro-time 抽查（check_inheritance_block.sh 保留作为
# 抽查工具，不再被 hook 调用）。
# v1.4 (2026-05-04)：加 gate ② deferred-work schema v1 — staged diff 含
# deferred-work.md 改动时校验新增 FU bullet 必带 4-tag 头 + 拒绝老 inline
# 后缀模式 + 拒绝 FU-RETRO-* 命名空间。仅扫新增行，不溯历史。详
# .claude/harness/conventions/deferred-work-schema.md §2.1.
# v1.5 (2026-05-05)：retro automation B 方案 — checker 按 category 分流，
# gate ① 只阻 dev 类 pending；harness 类仅 stderr WARN（不 block）。详
# .claude/harness/architecture.md §六 Q4 决策段。

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
RETRO_TRIGGER='_bmad-output/implementation-artifacts/[4-6]-.*\.md$'
RETRO_CHECKER=".claude/harness/scripts/check_retro_action_items.sh"
DEFERRED_WORK_PATH="_bmad-output/implementation-artifacts/deferred-work.md"

cd "$REPO_ROOT"

# `-c core.quotepath=false` 让 git 对 CJK 路径返回原始 UTF-8 而非 C-style
# 八进制转义；否则中文 retro / story 文件名会被双引号包裹，gate 触发 grep
# 漏匹配。当前 trigger pattern 都是 ASCII，但任何未来的 CJK retro 命名会
# 直接踩坑——一行防御性补丁，零成本。
GIT="git -c core.quotepath=false"

# E11: --diff-filter=A 仅命中"新增"路径；rename / delete / modify 现有 4-x-*.md
# 不触发（避免清理 / 重命名旧 spec 时被本 hook 误阻）。
ADDED_PATHS="$($GIT diff --cached --name-only --diff-filter=A || true)"

# ── Gate ① retro action items ─────────────────────────────────────────
if echo "$ADDED_PATHS" | grep -qE "$RETRO_TRIGGER"; then
    # E10: checker 文件存在性 + 可执行性 distinct probe，避免与"块缺失"撞 exit 1
    if [ ! -f "$RETRO_CHECKER" ]; then
        echo "ERROR: retro action items checker missing at $RETRO_CHECKER —" >&2
        echo "       expected to ship in repo per Epic 3 retro §C1." >&2
        echo "       cannot enforce; commit blocked. Run 'git stash && just install-git-hooks'" >&2
        echo "       or restore $RETRO_CHECKER from upstream." >&2
        exit 1
    fi

    if ! bash "$RETRO_CHECKER"; then
        cat >&2 <<'EOF'

ERROR: 仍有未兑现 dev 类 retro action items；不能创建新 epic 4-6 story spec
─────────────────────────────────────────────────────
注：仅 category: dev 的 pending/in-progress 项阻断本 gate；harness 类
    （流程脚本 / hook / skill / template / convention 等）显示为 WARN
    但不阻 epic 推进 — 详 .claude/harness/architecture.md §六 Q4。

处理路径：
  ① 兑现：跑掉缺失的 dev retro action item，把 sprint-status.yaml 对应 status
     翻 done / partial / deferred
  ② 显式跳过：git commit --no-verify
     爆炸半径：让 retro fail-safe 失效；必须**在被绕过的 retro action item
     自身 sprint-status.yaml 行注释里**加备注（commit message 是 ephemeral 的；
     yaml 注释持久，未来 retro 审计能看到跳过痕迹）
  ③ 查看明细：bash .claude/harness/scripts/check_retro_action_items.sh
  ④ harness 类待评估：tell main agent "评估 harness 优化" 进入 chore 实施流程
─────────────────────────────────────────────────────
依据：epic-3-retro-2026-05-03.md §C1 + §9.2 Epic 4 启动前 P0 列表
      + 2026-05-05 retro automation B 方案 category 分流
EOF
        exit 1
    fi
fi

# ── Gate ② deferred-work schema v1 ─────────────────────────────────────
# Triggered when staged diff modifies the deferred-work.md (any path component).
# Only ADDED lines (+ lines, excluding the +++ file header) are scanned —
# historical lines stay untouched. Three sub-checks:
#   (a) Any "- **FU-..." bullet head must carry the 4-tag block exactly once
#   (b) Legacy inline status suffix "— Resolved by Story X.Y (date):" forbidden
#   (c) FU-RETRO-* namespace forbidden (retro action items live in
#       sprint-status.yaml.retro_action_items)
if $GIT diff --cached --name-only | grep -qFx "$DEFERRED_WORK_PATH"; then
    # extract added lines (drop "+++" header marker; keep "+" body lines)
    ADDED="$($GIT diff --cached --unified=0 -- "$DEFERRED_WORK_PATH" \
             | grep -E '^\+' | grep -vE '^\+\+\+')"

    BAD_HEAD=""
    BAD_LEGACY=""
    BAD_RETRO=""

    if [ -n "$ADDED" ]; then
        # (a) FU bullet head must match 4-tag schema; strip leading "+"
        BAD_HEAD="$(echo "$ADDED" \
            | grep -E '^\+- \*\*FU-' \
            | grep -vE '^\+- \*\*FU-[A-Za-z0-9._\-]+\*\* `\[status:[a-z\-]+\]` `\[bucket:[a-zA-Z0-9.+\-]+\]` `\[target:[^]`]*\]` `\[source:[^]`]*\]`' \
            || true)"

        # (b) legacy inline suffix
        BAD_LEGACY="$(echo "$ADDED" \
            | grep -E '— (\*\*)?(Resolved|Partial resolution) by Story [0-9.]+(\*\*)? \([0-9]{4}-' \
            || true)"

        # (c) FU-RETRO-* namespace
        BAD_RETRO="$(echo "$ADDED" \
            | grep -E '^\+- \*\*FU-RETRO-' \
            || true)"
    fi

    if [ -n "$BAD_HEAD$BAD_LEGACY$BAD_RETRO" ]; then
        cat >&2 <<'EOF'

ERROR: deferred-work.md 新增内容违反 schema v1
─────────────────────────────────────────────────────
EOF
        if [ -n "$BAD_HEAD" ]; then
            echo "(a) FU bullet 头不符合 schema v1 4-tag 格式（新增行）：" >&2
            echo "$BAD_HEAD" | head -5 >&2
            cnt="$(echo "$BAD_HEAD" | wc -l | tr -d ' ')"
            [ "$cnt" -gt 5 ] && echo "    ... 还有 $((cnt-5)) 行未列出" >&2
            echo "" >&2
            echo "    期望：- **FU-X.Y.Z** \`[status:S]\` \`[bucket:B]\` \`[target:T]\` \`[source:O]\` — desc" >&2
            echo "    详见 .claude/harness/conventions/deferred-work-schema.md §2.1" >&2
            echo "" >&2
        fi
        if [ -n "$BAD_LEGACY" ]; then
            echo "(b) 老 inline 后缀模式已废弃（schema v1 §3.1）：" >&2
            echo "$BAD_LEGACY" | head -3 >&2
            echo "" >&2
            echo "    改为 [status:resolved] tag + 历史 audit log 子段。" >&2
            echo "" >&2
        fi
        if [ -n "$BAD_RETRO" ]; then
            echo "(c) FU-RETRO-* 命名空间禁止进 deferred-work.md（schema v1 §3.2）：" >&2
            echo "$BAD_RETRO" | head -3 >&2
            echo "" >&2
            echo "    retro action items 100% 归 sprint-status.yaml.retro_action_items。" >&2
            echo "" >&2
        fi
        cat >&2 <<'EOF'
处理路径：
  ① 修复：按 schema v1 改新增 FU bullet 头 / 删 inline 后缀 / 把 FU-RETRO-* 移到 sprint-status retro_action_items
  ② 显式跳过：git commit --no-verify  （会 silently 引入 schema drift 风险，仅极端急修使用）
  ③ Schema 文档：.claude/harness/conventions/deferred-work-schema.md
  ④ 工具链：bash .claude/harness/scripts/grep_deferred_buckets.sh   # 看当前总账
─────────────────────────────────────────────────────
EOF
        exit 1
    fi
fi

exit 0
